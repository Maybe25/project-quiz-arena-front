{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "shell": {
      "projectType": "application",
      "root": "projects/shell",
      "sourceRoot": "projects/shell/src",
      "prefix": "qa-shell",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "shell:_build",
            "federationConfig": "projects/shell/federation.config.js",
            "verbose": false
          },
          "configurations": {
            "production": {
              "target": "shell:_build:production"
            },
            "development": {
              "target": "shell:_build:development"
            }
          },
          "defaultConfiguration": "production"
        },
        "_build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/shell",
            "index": "projects/shell/src/index.html",
            "browser": "projects/shell/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/shell/tsconfig.app.json",
            "assets": [
              "projects/shell/src/favicon.ico",
              "projects/shell/src/assets",
              "projects/shell/src/federation.manifest.json",
              "projects/shell/src/manifest.webmanifest",
              "projects/shell/src/federation.manifest.prod.json"
            ],
            "styles": [
              "projects/shell/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "fileReplacements": [
                {
                  "replace": "projects/shell/src/environments/environment.ts",
                  "with": "projects/shell/src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "shell:_build:development",
            "federationConfig": "projects/shell/federation.config.js",
            "verbose": false,
            "dev": true,
            "port": 4200
          }
        }
      }
    },
